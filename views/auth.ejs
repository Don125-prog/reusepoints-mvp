<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Вход | ReUsePoints</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="center-page">
    <div class="auth-shell">
      <div class="brand-panel">
        <img src="/logo.png" alt="ReUsePoints" class="brand-logo">
        <h1 class="brand-title">ReUsePoints</h1>
        <p class="brand-subtitle">Передай ценное. Измени будущее.</p>

        <div class="brand-features">
          <div class="brand-feature">Подари новую жизнь</div>
          <div class="brand-feature">Делись с пользой</div>
          <div class="brand-feature">Объединяйся</div>
          <div class="brand-feature">Зарабатывай</div>
        </div>
      </div>

      <div class="form-panel">
        <div class="form-card">
          <h2 class="form-title">Вход в аккаунт</h2>
          <p class="form-subtitle">Введите свои данные и продолжите работу в системе.</p>

          <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
          <% } %>

          <% if (message) { %>
            <div class="alert alert-success"><%= message %></div>
          <% } %>

          <form action="/auth" method="POST">
            <label class="form-label">Email</label>
            <input
              class="input"
              type="email"
              name="email"
              placeholder="yourmail@example.com"
              required
            />

            <label class="form-label">Blockchain-аккаунт</label>
            <input
              class="input"
              type="text"
              name="blockchain_account"
              placeholder="0x..."
              required
            />

            <button class="btn btn-primary" type="submit">Войти</button>
          </form>

          <div class="link-row">
            Ещё нет аккаунта? <a href="/register">Зарегистрироваться</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>